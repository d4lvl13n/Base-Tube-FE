# BaseTube web frontend — environment variables
# Copy to .env (dev) and set real values. CRA only exposes REACT_APP_* vars.

# ── Required ────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash). Dev: http://localhost:3000
REACT_APP_API_URL=http://localhost:3000

# Clerk publishable key (pk_test_... in dev, pk_live_... in prod)
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# WalletConnect Cloud project id (wallet connect modal)
REACT_APP_WALLETCONNECT_PROJECT_ID=xxx

# Coinbase OnchainKit API key (Base Account wallet)
REACT_APP_ONCHAINKIT_API_KEY=xxx

# ── Feature flags ───────────────────────────────────────────────────────────
# Show the content-pass surfaces
REACT_APP_SHOW_PASSES=true
REACT_APP_FEATURE_ONCHAIN_PASSES=true

# Show the "testnet mode" badge (Base Sepolia deployments)
REACT_APP_TESTNET_MODE=false

# ── Optional ────────────────────────────────────────────────────────────────
# Override RPC endpoints used by wagmi (defaults to public RPCs)
# REACT_APP_BASE_MAINNET_RPC_URL=
# REACT_APP_BASE_SEPOLIA_RPC_URL=

# Public BaseTube API key for anonymous /v1/images/* thumbnail generation
# REACT_APP_BASETUBE_PUBLIC_API_KEY=bt_live_xxx

# Internal monitoring panels
# REACT_APP_ENABLE_INTERNAL_MONITORING=false

# Used by a couple of legacy call sites as an alias of REACT_APP_API_URL
# REACT_APP_API_BASE_URL=

# Removed/retired flags (do not set):
#   REACT_APP_CRYPTO_USE_RELAYER      — pre-Unlock relayer purchase path, deleted
#   REACT_APP_CONTENT_LEDGER_ABI_URL  — ContentLedger ABI fetch, deleted
